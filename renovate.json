{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "minimumReleaseAge": "14 days",
  "internalChecksFilter": "strict",
  "ignorePresets": [":ignoreModulesAndTests"],
  "packageRules": [
    {
      "matchDepNames": ["python", "gigabit-clowns/.github"],
      "enabled": false
    },
    {
      "description": "Security advisories bypass the 14-day delay",
      "matchUpdateTypes": ["security"],
      "minimumReleaseAge": "0 days"
    },
    {
      "matchDatasources": ["custom.half"],
      "extractVersion": "^/projects/half/files/half/(?<version>[0-9.]+)/$"
    }
  ],
  "customDatasources": {
    "half": {
      "defaultRegistryUrlTemplate": "https://sourceforge.net/projects/half/files/half/",
      "format": "html"
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["**/CMakeLists.txt"],
      "matchStrings": ["fetch_boost\\(VERSION (?<currentValue>[^)]+)\\)"],
      "depNameTemplate": "boost",
      "packageNameTemplate": "boostorg/boost",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^boost-(?<version>.*)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["**/CMakeLists.txt"],
      "matchStrings": ["fetch_half\\(VERSION (?<currentValue>[^)]+)\\)"],
      "depNameTemplate": "half",
      "datasourceTemplate": "custom.half"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["**/CMakeLists.txt"],
      "matchStrings": ["fetch_spdlog\\(VERSION (?<currentValue>[^)]+)\\)"],
      "depNameTemplate": "spdlog",
      "packageNameTemplate": "gabime/spdlog",
      "datasourceTemplate": "github-tags",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["**/CMakeLists.txt"],
      "matchStrings": ["fetch_catch2\\(VERSION (?<currentValue>[^)]+)\\)"],
      "depNameTemplate": "catch2",
      "packageNameTemplate": "catchorg/Catch2",
      "datasourceTemplate": "github-tags",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["**/CMakeLists.txt"],
      "matchStrings": ["fetch_trompeloeil\\(VERSION (?<currentValue>[^)]+)\\)"],
      "depNameTemplate": "trompeloeil",
      "packageNameTemplate": "rollbear/trompeloeil",
      "datasourceTemplate": "github-tags",
      "extractVersionTemplate": "^v(?<version>.*)$"
    }
  ]
}
